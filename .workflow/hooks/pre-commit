#!/usr/bin/env python3
"""
Git pre-commit hook: ensures commits happen only on branches with
an active workflow that has reached at least the 'create_branch' stage.

Install: copy to .git/hooks/pre-commit and chmod +x
Or: python .workflow/hooks/install.py
"""

import json
import subprocess
import sys
from pathlib import Path


def get_current_branch() -> str:
    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True, text=True
    )
    return result.stdout.strip()


def main():
    branch = get_current_branch()

    # Skip for main/develop branches (they get changes via PR)
    if branch in ("main", "develop", "HEAD"):
        sys.exit(0)

    # Look for an active workflow whose branch matches
    repo_root = Path(
        subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True
        ).stdout.strip()
    )
    workflow_dir = repo_root / ".workflow" / "active"
    if not workflow_dir.exists():
        sys.exit(0)  # No workflow system yet — allow

    for state_file in workflow_dir.glob("*.json"):
        with open(state_file) as f:
            state = json.load(f)

        if state.get("status") != "active":
            continue

        completed_stages = {s["stage_id"] for s in state.get("completed_stages", [])}
        branch_stage = next(
            (s for s in state.get("completed_stages", [])
             if s["stage_id"] == "create_branch"),
            None,
        )

        if branch_stage and branch_stage.get("artifacts", {}).get("branch_name") == branch:
            if "create_branch" in completed_stages:
                sys.exit(0)  # All good
            else:
                print("=" * 60, file=sys.stderr)
                print("  WORKFLOW GATE: COMMIT BLOCKED", file=sys.stderr)
                print("=" * 60, file=sys.stderr)
                print(f"  Branch '{branch}' has a workflow but hasn't", file=sys.stderr)
                print(f"  completed the 'create_branch' stage yet.", file=sys.stderr)
                print(f"  Task: {state['task_id']}", file=sys.stderr)
                print("", file=sys.stderr)
                print("  Complete prior stages first:", file=sys.stderr)
                print(f"    python .workflow/gate.py status {state['task_id']}", file=sys.stderr)
                print("=" * 60, file=sys.stderr)
                sys.exit(1)

    # No matching workflow found — warn but don't block
    print(f"WARNING: No active workflow found for branch '{branch}'.", file=sys.stderr)
    print(f"  Consider: python .workflow/gate.py start '<description>'", file=sys.stderr)
    sys.exit(0)


if __name__ == "__main__":
    main()
